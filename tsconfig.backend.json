{
  // backend(GAS)専用の型チェック設定。
  // clasp は rootDir(./backend) の tsconfig.json をコンパイルに使うため、
  // 型チェック用設定はリポジトリルートに置き backend/ には含めない。
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["google-apps-script"]
  },
  "include": ["backend/**/*.ts"]
}
