{
  "name": "bs-ageo9.org",
  "version": "1.0.0",
  "description": "ボーイスカウト上尾9団",
  "author": "limit7412",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=\"development\" npx nuxi dev",
    "build": "cross-env NODE_ENV=\"production\" npx nuxi build",
    "start": "cross-env NODE_ENV=\"production\" npx nuxi start",
    "generate": "cross-env NODE_ENV=\"production\" NITRO_PRESET=cloudflare_pages npx nuxi generate",
    "postinstall": "nuxi prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "nuxi typecheck"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "normalize.css": "^8.0.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@types/google-apps-script": "^2.0.11",
    "eslint": "^10.5.0",
    "nuxt": "^3.21.8",
    "prettier": "^3.6.2",
    "typescript": "~6.0.3",
    "vue-tsc": "^3.3.5"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
